        "scores": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "maxItems": 16,
          "minItems": 1,
          "description": "One scalar score per player slot."
        },
        "imposter": {
          "type": "array",
          "items": {
            "type": "integer",
            "maximum": 1,
            "minimum": 0
          },
          "maxItems": 16,
          "minItems": 1,
          "description": "One 1 or 0 flag for whether the player was an imposter."
        },
        "vote_skip": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          },
          "maxItems": 16,
          "minItems": 1,
          "description": "One count of explicit skip votes per player slot."
        },
        "vote_players": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          },
          "maxItems": 16,
          "minItems": 1,
          "description": "One count of votes cast for a player per player slot."
        },
        "vote_timeout": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          },
          "maxItems": 16,
          "minItems": 1,
          "description": "One count of vote timeouts per player slot."
        },
        "connect_timeout": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          },
          "maxItems": 16,
          "minItems": 1,
          "description": "One count of initial connection timeouts per player slot."
        },
        "disconnect_timeout": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          },
          "maxItems": 16,
          "minItems": 1,
          "description": "One count of reconnect timeouts per player slot."
        }
      },
      "additionalProperties": false
    }
  },
