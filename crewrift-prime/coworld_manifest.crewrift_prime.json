        "kills": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "maxItems": 16,
          "minItems": 1,
          "description": "One kill count per player slot."
        },
        "names": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 16,
          "minItems": 1,
          "description": "One player name or address per player slot."
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "maxItems": 16,
          "minItems": 1,
          "description": "One completed task count per player slot."
