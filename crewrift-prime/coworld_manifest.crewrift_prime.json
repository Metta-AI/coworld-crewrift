    "description": "Crewrift Prime \u2014 a forked social-deduction Crewrift coworld seeded for skill-tested play, with config-only scenario-parameterization variants (hunting, voting, task-pressure drills) per the parameterized-coworlds research. Derived league display name: \"Crewrift Prime\".",
    "config_schema": {
      "type": "object",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "required": [
        "tokens",
        "players"
      ],
      "properties": {
        "seed": {
          "type": "integer",
          "default": -1,
          "minimum": -1,
          "description": "Random seed. Use -1 to pick a time-based seed."
        },
        "slots": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": {
                "enum": [
                  "crew",
                  "imposter"
                ],
                "type": "string"
              },
              "color": {
                "enum": [
                  "red",
                  "orange",
                  "yellow",
                  "light blue",
                  "pink",
                  "lime",
                  "blue",
                  "pale blue",
                  "gray",
                  "white",
                  "dark brown",
                  "brown",
                  "dark teal",
                  "green",
                  "dark navy",
                  "black"
                ],
                "type": "string"
              },
              "token": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "default": [],
          "maxItems": 16,
          "description": "Optional fixed player slot role, color, and token settings."
        },
        "tokens": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "maxItems": 8,
          "minItems": 8,
          "description": "One connection token per player slot, indexed by slot."
        },
        "mapPath": {
          "type": "string",
          "default": "data/croatoan.resources",
          "description": "Resource map file path."
        },
        "players": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "maxItems": 8,
          "minItems": 8,
          "description": "One player display-name object per player slot, indexed by slot."
        },
        "maxGames": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "description": "Maximum games before shutdown."
        },
        "maxTicks": {
          "type": "integer",
          "default": 10000,
          "minimum": 0,
          "description": "Maximum task-phase game ticks, where 0 means no limit."
        },
        "killRange": {
          "type": "integer",
          "default": 20,
          "minimum": 0,
          "description": "Kill interaction range."
        },
        "ventRange": {
          "type": "integer",
          "default": 16,
          "minimum": 0,
          "description": "Vent interaction range."
        },
        "minPlayers": {
          "type": "integer",
          "default": 8,
          "maximum": 16,
          "minimum": 1,
          "description": "Players needed before the game countdown starts."
        },
        "buttonCalls": {
          "type": "integer",
          "default": 1,
          "minimum": 0,
          "description": "Emergency button calls allowed per player."
        },
        "reportRange": {
          "type": "integer",
          "default": 20,
          "minimum": 0,
          "description": "Body report interaction range."
        },
        "closedRoster": {
          "type": "boolean",
          "default": false,
          "description": "Reject players outside the configured token/slot roster."
        },
        "gameOverTicks": {
          "type": "integer",
          "default": 360,
          "minimum": 0,
          "description": "Game over display duration in ticks."
        },
        "imposterCount": {
          "type": "integer",
          "default": 2,
          "maximum": 15,
          "minimum": 0,
          "description": "Fixed imposter count when autoImposterCount is false."
        },
        "showTaskArrows": {
          "type": "boolean",
          "default": true,
          "description": "Show arrows pointing to tasks."
        },
        "startWaitTicks": {
          "type": "integer",
          "default": 120,
          "minimum": 0,
          "description": "Lobby countdown ticks after enough players join."
        },
        "tasksPerPlayer": {
          "type": "integer",
          "default": 8,
          "minimum": 0,
          "description": "Tasks assigned to each crewmate."
        },
        "voteTimerTicks": {
          "type": "integer",
          "default": 1200,
          "minimum": 1,
          "description": "Voting phase duration in ticks."
        },
        "roleRevealTicks": {
          "type": "integer",
          "default": 120,
          "minimum": 0,
          "description": "Role reveal duration in ticks."
        },
        "showTaskBubbles": {
          "type": "boolean",
          "default": true,
          "description": "Show task bubbles."
        },
        "voteResultTicks": {
          "type": "integer",
          "default": 72,
          "minimum": 0,
          "description": "Vote result display duration in ticks."
        },
        "showPlayerLabels": {
          "type": "boolean",
          "default": true,
          "description": "Show player labels."
        },
        "autoImposterCount": {
          "type": "boolean",
          "default": false,
          "description": "Automatically choose imposter count from player count."
        },
        "killCooldownTicks": {
          "type": "integer",
          "default": 500,
          "minimum": 0,
          "description": "Kill cooldown duration in ticks."
        },
        "taskCompleteTicks": {
          "type": "integer",
          "default": 72,
          "minimum": 0,
          "description": "Task completion duration in ticks."
        },
        "connectTimeoutTicks": {
          "type": "integer",
          "default": 2880,
          "minimum": 0,
          "description": "Initial connection grace duration in ticks."
        },
        "messageCooldownTicks": {
          "type": "integer",
          "default": 100,
          "minimum": 0,
          "description": "Chat message cooldown in ticks."
        },
        "disconnectTimeoutTicks": {
          "type": "integer",
          "default": 720,
          "minimum": 0,
          "description": "Reconnect grace duration in ticks."
        }
      },
      "additionalProperties": false
    },
    "results_schema": {
      "type": "object",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
